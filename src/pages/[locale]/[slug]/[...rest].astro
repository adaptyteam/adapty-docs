---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import OperationPage from '../../../components/api-reference/OperationPage.astro';
import apiConfig from '../../../api-reference/config.json';
import { loadSpec } from '../../../api-reference/lib/load-spec';
import { buildApiSpec } from '../../../api-reference/lib/model';
import { buildSidebar } from '../../../api-reference/lib/build-sidebar';
import { getBuildLocales } from '../../../data/locales';

export async function getStaticPaths() {
  const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
  const paths: Array<{ params: any; props: any }> = [];
  for (const locale of getBuildLocales()) {
    const localeBase = `${baseUrl}/${locale}`;
    for (const api of apiConfig) {
      const deref = await loadSpec(api.specFile, locale);
      const spec = buildApiSpec(deref, api, localeBase);
      for (const op of spec.operations) {
        paths.push({
          params: { locale, slug: api.slug, rest: `operations/${op.operationId}` },
          props: { api, locale, opId: op.operationId },
        });
      }
    }
  }
  return paths;
}

const { api, locale, opId } = Astro.props;
const { slug } = Astro.params;
const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
const localeBase = `${baseUrl}/${locale}`;

const deref = await loadSpec(api.specFile, locale);
const spec = buildApiSpec(deref, api, localeBase);
const operation = spec.operations.find(o => o.operationId === opId)!;
const sidebarData = buildSidebar(spec, localeBase, {
  backTo: api.backTo,
  backToLabel: api.backToLabel,
});

const breadcrumbs = [
  { label: 'Home', href: `${baseUrl}/` },
  { label: api.name, href: `${localeBase}/${slug}` },
  { label: operation.summary },
];
---

<DocsLayout
  title={`${operation.summary} (API)`}
  description={operation.summary}
  keywords={operation.summary}
  rank={70}
  sidebarData={sidebarData}
  currentPlatformId="api"
  currentSlug={`${slug}/operations/${operation.operationId}`}
  currentLocale={locale}
  breadcrumbs={breadcrumbs}
>
  <OperationPage spec={spec} operation={operation} />
</DocsLayout>
