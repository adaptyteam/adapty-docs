---
import DocsLayout from "../layouts/DocsLayout.astro";

// Served by S3 static-website hosting as the error document for any unknown
// URL under /docs (the bucket's error document is already set to 404.html).
// English-only by design — one page recovers visitors from any locale prefix,
// including AI-hallucinated URLs that look like real docs.
const base = import.meta.env.BASE_URL; // "/docs"

// All recovery links carry ?ref=404 so analytics can attribute the click to
// this page. These links only exist here, so the param never leaks onto the
// regular in-article cards (CustomDocCardList builds its own hrefs).
const REF = "ref=404";
const withRef = (path: string) => path.replace(/\/{2,}/g, "/") + `?${REF}`;
const link = (id: string) => withRef(`${base}/${id}`);
const home = withRef(`${base}/`);

// ─── Recovery cards ──────────────────────────────────────────────────────────
// To edit: each group is { title, cards: [{ title, id, description }] }.
//  • add a card    → push { title, id, description } into a group's `cards`
//  • add a group   → push { title, cards: [...] } onto `cardGroups`
//  • reorder       → move items around; the page renders them top-to-bottom
// `id` is the article's filename id (e.g. ios-sdk-overview → /docs/ios-sdk-overview).
// Use `href` instead of `id` for a raw path (e.g. the homepage, whose id
// redirects and would strip the ?ref=404 tag). All links get ?ref=404 added.
const cardGroups = [
    {
        title: "Get started with Adapty",
        cards: [
            {
                title: "Welcome to Adapty",
                href: home,
                description: "New here? Start with a quick overview of Adapty.",
            },
            {
                title: "Is Adapty right for me?",
                id: "is-adapty-right-for-me",
                description:
                    "See what Adapty offers and whether it fits your use case.",
            },
            {
                title: "Quickstart guide",
                id: "quickstart",
                description:
                    "Integrate Adapty with the App Store, Google Play, Stripe, and more.",
            },
        ],
    },
    {
        title: "Integrate the Adapty SDK",
        cards: [
            {
                title: "iOS",
                id: "ios-sdk-overview",
                description: "Set up the Adapty SDK in your iOS app.",
            },
            {
                title: "Android",
                id: "android-sdk-overview",
                description: "Set up the Adapty SDK in your Android app.",
            },
            {
                title: "React Native",
                id: "react-native-sdk-overview",
                description: "Set up the Adapty SDK in your React Native app.",
            },
            {
                title: "Flutter",
                id: "flutter-sdk-overview",
                description: "Set up the Adapty SDK in your Flutter app.",
            },
            {
                title: "Unity",
                id: "unity-sdk-overview",
                description: "Set up the Adapty SDK in your Unity app.",
            },
            {
                title: "Kotlin Multiplatform",
                id: "kmp-sdk-overview",
                description: "Set up the Adapty SDK in your KMP app.",
            },
            {
                title: "Capacitor",
                id: "capacitor-sdk-overview",
                description: "Set up the Adapty SDK in your Capacitor app.",
            },
        ],
    },
    {
        title: "Go further",
        cards: [
            {
                title: "A/B tests",
                id: "ab-tests",
                description: "Test paywalls and pricing to lift conversion.",
            },
            {
                title: "Analytics",
                id: "analytics",
                description: "Track subscription metrics and revenue.",
            },
            {
                title: "Growth Autopilot",
                id: "autopilot",
                description: "Automatically optimize paywalls for revenue.",
            },
        ],
    },
    {
        title: "More revenue tools",
        cards: [
            {
                title: "Apple Ads Manager",
                id: "adapty-ads-manager",
                description:
                    "Track and optimize your Apple Search Ads campaigns.",
            },
            {
                title: "Adapty User Acquisition",
                id: "adapty-user-acquisition",
                description: "Measure your full app economy without an MMP.",
            },
            {
                title: "Adapty Mail",
                id: "adapty-mail",
                description:
                    "AI email campaigns that turn trials into subscribers.",
            },
        ],
    },
];
---

<DocsLayout
    title="Page not found | Adapty Docs"
    description="The page you're looking for doesn't exist or has moved. Jump to a popular page or search the docs."
    sidebarData={null}
    currentPlatformId=""
    currentSlug="404"
    headings={[]}
    breadcrumbs={[]}
    hideRightColumn={true}
    noindex={true}
>
    <div class="not-prose notfound">
        <p class="notfound-eyebrow">404</p>
        <h1 class="notfound-title">We couldn't find that page</h1>
        <p class="notfound-sub">
            The page you're looking for doesn't exist or may have moved. Search
            the docs from the header, or jump to one of the popular pages below.
        </p>
        <p class="notfound-path" id="attempted-path-wrap" hidden>
            <code id="attempted-path"></code> wasn't found.
        </p>

        <div class="notfound-actions">
            <a href={home} class="notfound-home">Homepage</a>
        </div>

        {
            cardGroups.map((group) => (
                <section class="notfound-group">
                    <p class="notfound-section-label">{group.title}</p>
                    <div class="notfound-grid">
                        {group.cards.map((card) => (
                            <a href={card.href ?? link(card.id)} class="doc-card">
                                <div class="doc-card-head">
                                    <h3 class="doc-card-title">{card.title}</h3>
                                    <svg
                                        class="doc-card-arrow"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        aria-hidden="true"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </div>
                                <p class="doc-card-description">
                                    {card.description}
                                </p>
                            </a>
                        ))}
                    </div>
                </section>
            ))
        }
    </div>
</DocsLayout>

<style>
    .notfound {
        max-width: 56rem;
        margin: 0 auto;
        padding: 2rem 0 4rem;
    }

    .notfound-eyebrow {
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: var(--accent-primary);
        margin: 0 0 0.5rem;
    }

    .notfound-title {
        font-size: 2rem;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin: 0 0 0.75rem;
    }

    .notfound-sub {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--text-secondary);
        margin: 0;
        max-width: 40rem;
    }

    .notfound-path {
        font-size: 0.875rem;
        color: var(--text-tertiary);
        margin: 0.75rem 0 0;
    }

    .notfound-path code {
        color: var(--accent-primary);
        background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
        padding: 0.125rem 0.375rem;
        border-radius: 0.375rem;
        font-size: 0.85em;
        word-break: break-all;
    }

    .notfound-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
        margin: 1.75rem 0 2.5rem;
    }

    /* Scoped under .notfound so it beats the global `.docs-prose a` color rule
     (which would otherwise tint the button text purple-on-purple). */
    .notfound .notfound-home {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.25rem;
        border-radius: 0.75rem;
        background: var(--accent-primary);
        color: #ffffff;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

    .notfound .notfound-home:hover {
        opacity: 0.9;
    }

    .notfound-group + .notfound-group {
        margin-top: 2.5rem;
    }

    .notfound-section-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin: 0 0 1rem;
    }

    .notfound-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    @media (min-width: 640px) {
        .notfound-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .notfound-grid {
            grid-template-columns: repeat(3, 1fr);
        }
        .notfound-title {
            font-size: 2.5rem;
        }
    }

    /* Card styling mirrors CustomDocCardList's .doc-card for visual consistency. */
    .doc-card {
        display: flex;
        flex-direction: column;
        padding: 1rem 1.25rem;
        border-radius: 0.75rem;
        border: 1px solid var(--border-primary);
        background: var(--bg-primary);
        box-shadow: var(--shadow-sm);
        transition: all 0.3s;
        text-decoration: none;
    }

    .doc-card:hover {
        box-shadow: var(--shadow-md);
        border-color: var(--border-secondary);
        background: var(--bg-hover);
    }

    .doc-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    .doc-card-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
        line-height: 1.3;
    }

    .doc-card-description {
        font-size: 12px;
        line-height: 1.6;
        color: var(--text-secondary);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .doc-card-arrow {
        width: 0.875rem;
        height: 0.875rem;
        color: var(--text-tertiary);
        flex-shrink: 0;
        margin-left: 0.5rem;
        transition: all 0.3s;
    }

    .doc-card:hover .doc-card-arrow {
        color: var(--text-secondary);
        transform: translateX(0.125rem);
    }

    :root.dark .doc-card-title,
    html.dark .doc-card-title,
    .dark .doc-card-title {
        color: #f1f5f9 !important;
    }

    :root.dark .doc-card-description,
    html.dark .doc-card-description,
    .dark .doc-card-description {
        color: #cbd5e1 !important;
    }
</style>

<script>
    function initNotFound() {
        // Echo the attempted path (S3 serves this page at the original URL with no
        // redirect, so window.location reflects the URL the visitor actually hit).
        const wrap = document.getElementById("attempted-path-wrap");
        const code = document.getElementById("attempted-path");
        if (wrap && code) {
            const path = window.location.pathname;
            // Skip the page's own build path (/docs/404) to avoid a nonsense message.
            if (path && !/\/404\/?$/.test(path)) {
                code.textContent = path;
                wrap.removeAttribute("hidden");
            }
        }
    }

    initNotFound();
    document.addEventListener("astro:page-load", initNotFound);
</script>
