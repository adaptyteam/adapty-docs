---
import DocsLayout from '../layouts/DocsLayout.astro';
import SpecLandingPage from '../components/api-reference/SpecLandingPage.astro';
import apiConfig from '../api-reference/config.json';
import { loadSpec } from '../api-reference/lib/load-spec';
import { buildApiSpec } from '../api-reference/lib/model';
import { buildSidebar } from '../api-reference/lib/build-sidebar';

export async function getStaticPaths() {
  const { isLocaleOnlyBuild } = await import('../data/locales');
  if (isLocaleOnlyBuild) return [];
  return apiConfig.map(api => ({ params: { slug: api.slug }, props: { api } }));
}

const { api } = Astro.props;
const { slug } = Astro.params;
const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');

const deref = await loadSpec(api.specFile);
const spec = buildApiSpec(deref, api, baseUrl);
const sidebarData = buildSidebar(spec, baseUrl, {
  backTo: api.backTo,
  backToLabel: api.backToLabel,
});

const breadcrumbs = [
  { label: 'Home', href: `${baseUrl}/` },
  { label: api.name },
];
---

<DocsLayout
  title={api.name}
  description={`${api.name} reference documentation`}
  keywords={api.name}
  rank={70}
  sidebarData={sidebarData}
  currentPlatformId="api"
  currentSlug={slug}
  breadcrumbs={breadcrumbs}
>
  <SpecLandingPage spec={spec} />
</DocsLayout>
