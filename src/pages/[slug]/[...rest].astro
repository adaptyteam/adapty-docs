---
import DocsLayout from '../../layouts/DocsLayout.astro';
import OperationPage from '../../components/api-reference/OperationPage.astro';
import apiConfig from '../../api-reference/config.json';
import apiPlatformSidebar from '../../data/sidebars/api.json';
import { loadSpec } from '../../api-reference/lib/load-spec';
import { buildApiSpec } from '../../api-reference/lib/model';
import { buildSidebar } from '../../api-reference/lib/build-sidebar';
import { forceCollapseTopLevel } from '../../api-reference/lib/force-collapse';

export async function getStaticPaths() {
  const { isLocaleOnlyBuild } = await import('../../data/locales');
  if (isLocaleOnlyBuild) return [];

  const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
  const paths: Array<{ params: any; props: any }> = [];
  for (const api of apiConfig) {
    const deref = await loadSpec(api.specFile);
    const spec = buildApiSpec(deref, api, baseUrl);
    for (const op of spec.operations) {
      paths.push({
        params: { slug: api.slug, rest: `operations/${op.operationId}` },
        props: { api, opId: op.operationId },
      });
    }
  }
  return paths;
}

const { api, opId } = Astro.props;
const { slug } = Astro.params;
const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');

const deref = await loadSpec(api.specFile);
const spec = buildApiSpec(deref, api, baseUrl);
const operation = spec.operations.find(o => o.operationId === opId)!;
const sidebarData = forceCollapseTopLevel(apiPlatformSidebar);
const apiSidebarData = buildSidebar(spec, baseUrl);

const breadcrumbs = [
  { label: 'Home', href: `${baseUrl}/` },
  { label: api.name, href: `${baseUrl}/${slug}` },
  { label: operation.summary },
];
---

<DocsLayout
  title={`${operation.summary} (API)`}
  description={operation.summary}
  keywords={operation.summary}
  rank={70}
  sidebarData={sidebarData}
  apiSidebarData={apiSidebarData}
  currentPlatformId="api"
  currentSlug={`${slug}/operations/${operation.operationId}`}
  breadcrumbs={breadcrumbs}
  hideRightColumn={true}
>
  <OperationPage spec={spec} operation={operation} />
</DocsLayout>
