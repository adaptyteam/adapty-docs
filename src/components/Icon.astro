---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

interface Props {
  name: string;
}

const { name } = Astro.props;
const iconsDir = fileURLToPath(new URL('../assets/icons', import.meta.url));
const svgPath = path.resolve(iconsDir, `${name}.svg`);

if (!svgPath.startsWith(iconsDir + path.sep)) {
  throw new Error(`Icon name "${name}" resolves outside the icons directory`);
}

let svgContent: string;
try {
  svgContent = fs.readFileSync(svgPath, 'utf-8');
} catch {
  const files = fs.readdirSync(iconsDir, { recursive: true }) as string[];
  const available = files
    .filter(f => f.endsWith('.svg'))
    .map(f => f.replace('.svg', ''))
    .join(', ');
  throw new Error(`Icon "${name}" not found. Available: ${available}`);
}
---
<span class="inline-icon" role="presentation" aria-hidden="true" set:html={svgContent} />
