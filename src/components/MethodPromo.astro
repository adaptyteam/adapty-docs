---
import platformsData from '../data/platforms.json';
import { SUPPORTED_LOCALES } from '../data/locales';

interface Item {
  title: string;
  desc: string;
}

interface Props {
  method: string;
  label?: string;
  items?: Item[];
  note?: string;
  noteHref?: string;
  noteLinkText?: string;
}

// Resolve which platform sidebar this page belongs to
const sidebars = import.meta.glob('../data/sidebars/*.json', { eager: true });
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop() ?? '';

function containsSlug(items: any[], target: string): boolean {
  for (const item of items) {
    const id = item.id ?? item.link?.id;
    if (id === target) return true;
    if (item.items && containsSlug(item.items, target)) return true;
  }
  return false;
}

let platformId: string | null = null;
for (const [filepath, mod] of Object.entries(sidebars)) {
  const filename = filepath.split('/').pop()!;
  const pid = filename.replace('.json', '');
  if (!platformsData.sdkPlatforms.some(p => p.id === pid)) continue;
  if (containsSlug((mod as any).default, currentSlug)) {
    platformId = pid;
    break;
  }
}

const manualSlug = platformId ? `${platformId}-quickstart-manual` : null;

// Localized fallback text for the component's defaults. Props passed in MDX
// (label/items/note/...) are translated by the translate script, but the
// defaults below live in this component, so they must be localized here.
// {method} is replaced with the actual method name and rendered as <code>.
// Auto-translation only touches MDX in src/locales — add a new entry when
// adding a locale (see the localize skill).
const T: Record<string, { label: string; items: Item[]; note: string; noteLinkText: string }> = {
  en: {
    label: 'What {method} retrieves',
    items: [
      { title: 'Flows', desc: 'Built in Flow builder — renders natively on device, no WebView' },
      { title: 'Paywall Builder paywalls', desc: 'All existing Paywall Builder content' },
    ],
    note: 'Building a custom paywall?',
    noteLinkText: 'See the manual integration guide.',
  },
  zh: {
    label: '{method} 获取的内容',
    items: [
      { title: '流程', desc: '在 Flow Builder 中构建——在设备上原生渲染，无需 WebView' },
      { title: 'Paywall Builder 付费墙', desc: '所有现有的 Paywall Builder 内容' },
    ],
    note: '正在构建自定义付费墙？',
    noteLinkText: '查看手动集成指南。',
  },
  tr: {
    label: '{method} ile alınanlar',
    items: [
      { title: "Flow'lar", desc: "Flow Builder ile oluşturulur — cihazda natif olarak render edilir, WebView gerekmez" },
      { title: "Paywall Builder paywall'ları", desc: 'Mevcut tüm Paywall Builder içeriği' },
    ],
    note: 'Özel paywall mı oluşturuyorsunuz?',
    noteLinkText: 'Manuel entegrasyon rehberine bakın.',
  },
  ru: {
    label: 'Что возвращает {method}',
    items: [
      { title: 'Флоу', desc: 'Создаются в Flow Builder — рендерятся нативно на устройстве, без WebView' },
      { title: 'Пейволы Paywall Builder', desc: 'Весь существующий контент Paywall Builder' },
    ],
    note: 'Создаёте кастомный пейвол?',
    noteLinkText: 'См. руководство по ручной интеграции.',
  },
  es: {
    label: 'Lo que devuelve {method}',
    items: [
      { title: 'Flows', desc: 'Creados en el Flow Builder — se renderizan de forma nativa en el dispositivo, sin WebView' },
      { title: 'Paywalls de Paywall Builder', desc: 'Todo el contenido existente de Paywall Builder' },
    ],
    note: '¿Estás creando un paywall personalizado?',
    noteLinkText: 'Consulta la guía de integración manual.',
  },
  ja: {
    label: '{method} で取得される内容',
    items: [
      { title: 'フロー', desc: 'Flow Builder で作成——デバイス上でネイティブにレンダリングされ、WebView は不要' },
      { title: 'Paywall Builder のペイウォール', desc: '既存のすべての Paywall Builder コンテンツ' },
    ],
    note: 'カスタムペイウォールを作成しますか？',
    noteLinkText: '手動連携ガイドを参照してください。',
  },
  vi: {
    label: 'Nội dung mà {method} trả về',
    items: [
      { title: 'Flow', desc: 'Được tạo trong Flow Builder — render nguyên bản trên thiết bị, không cần WebView' },
      { title: 'Paywall của Paywall Builder', desc: 'Toàn bộ nội dung Paywall Builder hiện có' },
    ],
    note: 'Đang xây dựng paywall tùy biến?',
    noteLinkText: 'Xem hướng dẫn tích hợp thủ công.',
  },
};

// Detect locale from the URL (/docs/{locale}/... on localized pages); English otherwise.
const localeSegments = Astro.url.pathname.split('/').filter(Boolean);
const locale = localeSegments.find((s) => (SUPPORTED_LOCALES as readonly string[]).includes(s)) ?? 'en';
const t = T[locale] ?? T.en;

const { method, label: rawLabel, items, note, noteHref: rawNoteHref, noteLinkText } = Astro.props;

// Split label around the method name so it renders as <code>
const labelText = rawLabel ?? t.label.replace('{method}', method);
const [labelBefore, labelAfter] = labelText.includes(method)
  ? labelText.split(method)
  : [labelText, null];

const resolvedItems = items ?? t.items;
const resolvedNote = note ?? t.note;
const resolvedNoteHref = rawNoteHref ?? manualSlug ?? undefined;
const resolvedNoteLinkText = noteLinkText ?? t.noteLinkText;
---

<div class="method-promo">
  <div class="method-promo-label">
    {labelBefore}{labelAfter !== null && <code class="method-promo-method">{method}</code>}{labelAfter}
  </div>
  <div class="method-promo-grid" style={`grid-template-columns: repeat(${resolvedItems.length}, 1fr);`}>
    {resolvedItems.map(item => (
      <div class="method-promo-item">
        <span class="method-promo-accent">✦</span>
        <div class="method-promo-item-body">
          <span class="method-promo-item-title">
            {item.title}
          </span>
          <span class="method-promo-item-desc">{item.desc}</span>
        </div>
      </div>
    ))}
  </div>
  {resolvedNote && resolvedNoteHref && (
    <div class="method-promo-footer">
      {resolvedNote}{' '}<a href={resolvedNoteHref} class="method-promo-link">{resolvedNoteLinkText}</a>
    </div>
  )}
</div>

<style>
  .method-promo {
    margin: 1.75rem 0;
    padding: 1.125rem 1.375rem 1.125rem;
    border-radius: 0.625rem;
    border: 1px solid color-mix(in srgb, #6720ff 18%, transparent);
    background: color-mix(in srgb, #6720ff 3.5%, white);
  }

  .dark .method-promo {
    background: color-mix(in srgb, #a78bfa 5%, #0f0f10);
    border-color: color-mix(in srgb, #a78bfa 22%, transparent);
  }

  .method-promo-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #7c3aed;
    margin-bottom: 0.875rem;
    line-height: 1;
  }

  .dark .method-promo-label {
    color: #a78bfa;
  }

  /* Tailwind typography adds backtick pseudo-elements to code — reset them here */
  .method-promo code::before,
  .method-promo code::after {
    content: '';
  }

  .method-promo-method {
    font-family: var(--font-mono, 'Fira Code', monospace);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.075rem 0.3rem;
    border-radius: 0.25rem;
    background: color-mix(in srgb, #6720ff 12%, transparent);
    color: inherit;
    vertical-align: baseline;
  }

  .dark .method-promo-method {
    background: color-mix(in srgb, #a78bfa 14%, transparent);
  }

  .method-promo-grid {
    display: grid;
    gap: 0.75rem 1.25rem;
  }

  @media (max-width: 580px) {
    .method-promo-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .method-promo-item {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .method-promo-accent {
    flex-shrink: 0;
    font-size: 0.625rem;
    line-height: 1;
    margin-top: 0.2rem;
    color: #7c3aed;
    user-select: none;
  }

  .dark .method-promo-accent {
    color: #a78bfa;
  }

  .method-promo-item-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .method-promo-item-title {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.3;
  }

  .dark .method-promo-item-title {
    color: #f1f5f9;
  }

  .method-promo-item-desc {
    font-size: 0.75rem;
    line-height: 1.45;
    color: #6b7280;
  }

  .dark .method-promo-item-desc {
    color: #94a3b8;
  }

  .method-promo-footer {
    margin-top: 0.875rem;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in srgb, #6720ff 12%, transparent);
    font-size: 0.78125rem;
    line-height: 1.5;
    color: #7c3aed;
  }

  .dark .method-promo-footer {
    border-top-color: color-mix(in srgb, #a78bfa 18%, transparent);
    color: #a78bfa;
  }

  .method-promo-link {
    font-weight: 600;
    color: #6720ff;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .dark .method-promo-link {
    color: #a78bfa;
  }

  .method-promo-link:hover {
    opacity: 0.75;
  }
</style>
