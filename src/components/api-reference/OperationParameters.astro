---
// src/components/api-reference/OperationParameters.astro
import type { ApiParameter } from '../../api-reference/lib/model';

interface Props { parameters: ApiParameter[]; }
const { parameters } = Astro.props;

const groups = ['path', 'query', 'header'] as const;
const grouped = Object.fromEntries(
  groups.map(g => [g, parameters.filter(p => p.in === g)])
) as Record<typeof groups[number], ApiParameter[]>;

const labels: Record<string, string> = {
  path: 'Path parameters',
  query: 'Query parameters',
  header: 'Header parameters',
};
---

{groups.map(g => grouped[g].length > 0 && (
  <section class="api-params">
    <h3>{labels[g]}</h3>
    <div class="schema-list">
      {grouped[g].map(p => (
        <div class="schema-row">
          <div class="schema-row-header">
            <span class="schema-name">{p.name}</span>
            <span class="schema-type">
              {p.schema.type ?? 'any'}{p.schema.format ? ` · ${p.schema.format}` : ''}
            </span>
            {p.required && <span class="schema-required">required</span>}
          </div>
          {p.descriptionHtml && (
            <div class="schema-desc" set:html={p.descriptionHtml} />
          )}
        </div>
      ))}
    </div>
  </section>
))}

<style>
  .api-params { margin: 2rem 0; }
</style>
