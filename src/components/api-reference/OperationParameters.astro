---
// src/components/api-reference/OperationParameters.astro
import type { ApiParameter } from '../../api-reference/lib/model';

interface Props { parameters: ApiParameter[]; }
const { parameters } = Astro.props;

const groups = ['path', 'query', 'header'] as const;
const grouped = Object.fromEntries(
  groups.map(g => [g, parameters.filter(p => p.in === g)])
) as Record<typeof groups[number], ApiParameter[]>;

const labels: Record<string, string> = { path: 'Path parameters', query: 'Query parameters', header: 'Header parameters' };
---

{groups.map(g => grouped[g].length > 0 && (
  <section class="api-params">
    <h3>{labels[g]}</h3>
    <table>
      <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
      <tbody>
        {grouped[g].map(p => (
          <tr>
            <td>
              <code>{p.name}</code>
              {p.required && <span class="required" title="Required">*</span>}
            </td>
            <td><code>{p.schema.type ?? 'any'}{p.schema.format ? ` (${p.schema.format})` : ''}</code></td>
            <td set:html={p.descriptionHtml} />
          </tr>
        ))}
      </tbody>
    </table>
  </section>
))}

<style>
.api-params { margin: 1.5rem 0; }
.api-params h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary); }
.api-params table { width: 100%; border-collapse: collapse; }
.api-params th, .api-params td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border-primary);
  text-align: left; vertical-align: top; font-size: 0.875rem; }
.api-params th { font-weight: 600; color: var(--text-secondary); }
.api-params .required { color: #dc2626; margin-left: 0.25rem; }
</style>
