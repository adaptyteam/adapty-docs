---
// src/components/api-reference/CodeSamplesBlock.astro
import type { ApiOperation, ApiSpec } from '../../api-reference/lib/model';
import { renderCurl, renderFetch, renderPython } from '../../api-reference/lib/code-samples';
import LanguageSwitcher from './LanguageSwitcher.tsx';

interface Props { operation: ApiOperation; spec: ApiSpec; }
const { operation, spec } = Astro.props;

const samples = {
  curl: renderCurl({ operation, spec }),
  fetch: renderFetch({ operation, spec }),
  python: renderPython({ operation, spec }),
};

const harRequest = {
  method: operation.method,
  url: operation.serverUrl + operation.path,
  headers: Object.entries({
    ...(operation.requestBody ? { 'Content-Type': operation.requestBody.contentType } : {}),
  }).map(([name, value]) => ({ name, value })),
  postData: operation.requestBody?.examples[0]
    ? { mimeType: operation.requestBody.contentType,
        text: JSON.stringify(operation.requestBody.examples[0].value, null, 2) }
    : undefined,
};
---

<aside class="api-code-samples" data-op-id={operation.operationId}>
  <div class="api-code-samples-header">
    <span>Request</span>
    <LanguageSwitcher
      client:visible
      operationId={operation.operationId}
      harRequest={harRequest}
    />
  </div>
  <div class="api-code-sample" data-lang="curl"><pre><code>{samples.curl}</code></pre></div>
  <div class="api-code-sample" data-lang="fetch" hidden><pre><code>{samples.fetch}</code></pre></div>
  <div class="api-code-sample" data-lang="python" hidden><pre><code>{samples.python}</code></pre></div>
  <div class="api-code-sample api-code-sample-dynamic" data-lang="dynamic" hidden><pre><code></code></pre></div>
</aside>

<style>
.api-code-samples { background: var(--bg-secondary); border-radius: 0.75rem; overflow: hidden;
  font-family: var(--font-mono); }
.api-code-samples-header { display: flex; justify-content: space-between; align-items: center;
  padding: 0.5rem 0.875rem; border-bottom: 1px solid var(--border-primary);
  font-size: 0.8125rem; color: var(--text-secondary); }
.api-code-sample pre { padding: 0.875rem; margin: 0; overflow-x: auto;
  font-size: 0.8125rem; line-height: 1.5; color: var(--text-primary); }
.api-code-sample code { background: transparent; }
</style>
