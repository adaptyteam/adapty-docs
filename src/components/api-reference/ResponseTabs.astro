---
// src/components/api-reference/ResponseTabs.astro
import type { ApiResponse } from '../../api-reference/lib/model';
import SchemaTree from './SchemaTree.astro';

interface Props { responses: ApiResponse[]; opId: string; }
const { responses, opId } = Astro.props;

function statusClass(code: string): string {
  if (code.startsWith('2')) return 'ok';
  if (code.startsWith('3')) return 'redir';
  if (code.startsWith('4')) return 'client';
  if (code.startsWith('5')) return 'server';
  return '';
}
---

<section class="api-responses">
  <h3>Responses</h3>
  <div class="response-tabs">
    {responses.map((r, i) => (
      <input
        type="radio"
        name={`resp-${opId}`}
        id={`resp-${opId}-${r.statusCode}`}
        class="response-radio"
        checked={i === 0}
      />
    ))}
    <nav class="response-tab-labels">
      {responses.map(r => (
        <label
          for={`resp-${opId}-${r.statusCode}`}
          class:list={['response-tab-label', statusClass(r.statusCode)]}
        >
          {r.statusCode}
        </label>
      ))}
    </nav>
    {responses.map(r => (
      <div class="response-tab-panel" data-status={r.statusCode}>
        <div class="response-desc" set:html={r.descriptionHtml} />
        {r.schema && (
          <details class="response-schema" open>
            <summary>Schema</summary>
            <SchemaTree schema={r.schema} />
          </details>
        )}
        {r.examples.length > 0 && (
          <details class="response-examples" open>
            <summary>Example</summary>
            <pre><code>{JSON.stringify(r.examples[0].value, null, 2)}</code></pre>
          </details>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .api-responses { margin: 2.5rem 0; }
  .response-tabs { position: relative; }
  .response-radio { position: absolute; opacity: 0; pointer-events: none; }

  .response-tab-labels {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--border-primary);
    margin-bottom: 1.25rem;
  }

  .response-tab-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    margin-bottom: -1px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .response-tab-label::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-secondary);
    opacity: 0.6;
  }
  .response-tab-label.ok::before { background: #16a34a; opacity: 1; }
  .response-tab-label.client::before { background: #d97706; opacity: 1; }
  .response-tab-label.server::before { background: #dc2626; opacity: 1; }
  .response-tab-label:hover { color: var(--text-primary); }

  .response-tab-panel { display: none; }

  /* Map each radio to its label and panel by source order. */
  .response-radio:nth-of-type(1):checked ~ .response-tab-labels label:nth-of-type(1),
  .response-radio:nth-of-type(2):checked ~ .response-tab-labels label:nth-of-type(2),
  .response-radio:nth-of-type(3):checked ~ .response-tab-labels label:nth-of-type(3),
  .response-radio:nth-of-type(4):checked ~ .response-tab-labels label:nth-of-type(4),
  .response-radio:nth-of-type(5):checked ~ .response-tab-labels label:nth-of-type(5),
  .response-radio:nth-of-type(6):checked ~ .response-tab-labels label:nth-of-type(6) {
    border-bottom-color: var(--accent-primary);
    color: var(--text-primary);
    font-weight: 600;
  }
  .response-radio:nth-of-type(1):checked ~ .response-tab-panel:nth-of-type(1),
  .response-radio:nth-of-type(2):checked ~ .response-tab-panel:nth-of-type(2),
  .response-radio:nth-of-type(3):checked ~ .response-tab-panel:nth-of-type(3),
  .response-radio:nth-of-type(4):checked ~ .response-tab-panel:nth-of-type(4),
  .response-radio:nth-of-type(5):checked ~ .response-tab-panel:nth-of-type(5),
  .response-radio:nth-of-type(6):checked ~ .response-tab-panel:nth-of-type(6) {
    display: block;
  }

  .response-desc {
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 64ch;
  }

  /* Flatten the global details "card" treatment for inline schema/example blocks
     so they read as continuations of the response panel, not separate UI panels. */
  .api-responses :global(details.response-schema),
  .api-responses :global(details.response-examples) {
    margin: 1.25rem 0 0 !important;
    border: none !important;
    border-top: 1px solid var(--border-primary) !important;
    border-radius: 0 !important;
    background: transparent !important;
    padding: 0 !important;
    box-shadow: none !important;
  }
  .api-responses :global(details.response-schema:hover),
  .api-responses :global(details.response-examples:hover) {
    border-color: var(--border-primary) !important;
    box-shadow: none !important;
  }
  .api-responses :global(details.response-schema > summary),
  .api-responses :global(details.response-examples > summary) {
    padding: 0.875rem 0 !important;
    background: transparent !important;
    font-size: 0.6875rem !important;
    font-weight: 600 !important;
    color: var(--text-secondary) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
  }
  .api-responses :global(details.response-schema > summary:hover),
  .api-responses :global(details.response-examples > summary:hover) {
    background: transparent !important;
    color: var(--text-primary) !important;
  }
  .api-responses :global(details.response-schema[open] > summary),
  .api-responses :global(details.response-examples[open] > summary) {
    color: var(--text-primary) !important;
  }
  .api-responses :global(details.response-schema > *:not(summary)),
  .api-responses :global(details.response-examples > *:not(summary)) {
    padding: 0 0 0.5rem 0 !important;
    margin: 0 !important;
    color: inherit !important;
    font-size: inherit !important;
    line-height: inherit !important;
    background: transparent !important;
  }
  .api-responses :global(details.response-examples > pre) {
    padding: 1rem !important;
    background: var(--bg-secondary) !important;
    border-radius: 0.5rem !important;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.55;
  }
</style>
