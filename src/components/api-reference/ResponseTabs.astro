---
// src/components/api-reference/ResponseTabs.astro
import type { ApiResponse } from '../../api-reference/lib/model';
import SchemaTree from './SchemaTree.astro';

interface Props { responses: ApiResponse[]; opId: string; }
const { responses, opId } = Astro.props;

function statusClass(code: string): string {
  if (code.startsWith('2')) return 'ok';
  if (code.startsWith('3')) return 'redir';
  if (code.startsWith('4')) return 'client';
  if (code.startsWith('5')) return 'server';
  return '';
}
---

<section class="api-responses">
  <h3>Responses</h3>
  <div class="response-tabs">
    {responses.map((r, i) => (
      <input
        type="radio"
        name={`resp-${opId}`}
        id={`resp-${opId}-${r.statusCode}`}
        class="response-radio"
        checked={i === 0}
      />
    ))}
    <div class="response-tab-labels">
      {responses.map(r => (
        <label
          for={`resp-${opId}-${r.statusCode}`}
          class:list={['response-tab-label', statusClass(r.statusCode)]}
        >
          {r.statusCode}
        </label>
      ))}
    </div>
    {responses.map(r => (
      <div class="response-tab-panel" data-status={r.statusCode}>
        <div class="response-desc" set:html={r.descriptionHtml} />
        {r.schema && (
          <details class="response-schema" open>
            <summary>Schema</summary>
            <SchemaTree schema={r.schema} />
          </details>
        )}
        {r.examples.length > 0 && (
          <details class="response-examples" open>
            <summary>Example</summary>
            <pre><code>{JSON.stringify(r.examples[0].value, null, 2)}</code></pre>
          </details>
        )}
      </div>
    ))}
  </div>
</section>

<style>
.api-responses { margin: 2rem 0; }
.response-tabs { position: relative; }
.response-radio { position: absolute; opacity: 0; pointer-events: none; }
.response-tab-labels { display: flex; gap: 0.5rem; border-bottom: 1px solid var(--border-primary); margin-bottom: 1rem; }
.response-tab-label { padding: 0.5rem 0.875rem; cursor: pointer; font-family: var(--font-mono);
  font-size: 0.875rem; border-bottom: 2px solid transparent; }
.response-tab-label.ok { color: #16a34a; }
.response-tab-label.client { color: #ea580c; }
.response-tab-label.server { color: #dc2626; }
.response-tab-panel { display: none; }
/* CSS sibling selectors map each radio to its panel by source order */
.response-radio:nth-of-type(1):checked ~ .response-tab-labels label:nth-of-type(1),
.response-radio:nth-of-type(2):checked ~ .response-tab-labels label:nth-of-type(2),
.response-radio:nth-of-type(3):checked ~ .response-tab-labels label:nth-of-type(3),
.response-radio:nth-of-type(4):checked ~ .response-tab-labels label:nth-of-type(4),
.response-radio:nth-of-type(5):checked ~ .response-tab-labels label:nth-of-type(5),
.response-radio:nth-of-type(6):checked ~ .response-tab-labels label:nth-of-type(6) {
  border-bottom-color: var(--accent-primary); font-weight: 600;
}
.response-radio:nth-of-type(1):checked ~ .response-tab-panel:nth-of-type(1),
.response-radio:nth-of-type(2):checked ~ .response-tab-panel:nth-of-type(2),
.response-radio:nth-of-type(3):checked ~ .response-tab-panel:nth-of-type(3),
.response-radio:nth-of-type(4):checked ~ .response-tab-panel:nth-of-type(4),
.response-radio:nth-of-type(5):checked ~ .response-tab-panel:nth-of-type(5),
.response-radio:nth-of-type(6):checked ~ .response-tab-panel:nth-of-type(6) {
  display: block;
}
.response-tab-panel pre { background: var(--bg-secondary); padding: 0.75rem; border-radius: 0.5rem;
  overflow-x: auto; font-size: 0.8125rem; }
.response-desc { color: var(--text-secondary); margin-bottom: 0.75rem; }
</style>
