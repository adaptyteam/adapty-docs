---
// src/components/api-reference/SpecHeader.astro
import type { ApiSpec } from '../../api-reference/lib/model';

interface Props { spec: ApiSpec; }
const { spec } = Astro.props;
---

<header class="api-spec-header">
  <div class="api-spec-header-row">
    <h1 class="api-spec-title">{spec.name}</h1>
    {spec.version && <span class="api-spec-version">v{spec.version}</span>}
  </div>
  <a class="api-spec-download" href={spec.specFileUrl} download>
    Download OpenAPI spec
  </a>
</header>

<style>
.api-spec-header { display: flex; justify-content: space-between; align-items: center;
  gap: 1rem; flex-wrap: wrap; padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-primary); margin-bottom: 1.5rem; }
.api-spec-header-row { display: flex; align-items: baseline; gap: 0.75rem; }
.api-spec-title { margin: 0; font-size: 1.875rem; font-weight: 700; color: var(--text-primary); }
.api-spec-version { font-size: 0.875rem; color: var(--text-secondary);
  background: var(--bg-secondary); padding: 0.125rem 0.5rem; border-radius: 0.5rem; }
.api-spec-download { font-size: 0.875rem; color: var(--accent-primary);
  text-decoration: none; border: 1px solid var(--border-primary); padding: 0.5rem 0.875rem;
  border-radius: 0.5rem; transition: background 0.15s; }
.api-spec-download:hover { background: var(--bg-secondary); }
</style>
