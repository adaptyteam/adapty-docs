---
interface Props {
  id: string;
  alt: string;
  width?: string;
}

const { id, alt, width = '20px' } = Astro.props;

const isSvg = id.endsWith('.svg');
const normalizedId = id.split('/').pop() || id;

const allSvgs = import.meta.glob<string>(
  '/src/assets/Inline/**/*.svg',
  { query: '?raw', eager: true, import: 'default' }
);

let svgContent: string | undefined;
if (isSvg) {
  for (const [path, raw] of Object.entries(allSvgs)) {
    if (path.split('/').pop() === normalizedId) {
      svgContent = raw;
      break;
    }
  }
}

const allImages = isSvg ? {} : import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/Inline/**/*.{png,jpg,jpeg,webp,gif}',
  { eager: true }
);

let imageSrc: ImageMetadata | undefined;

if (!isSvg) {
  for (const [path, module] of Object.entries(allImages)) {
    if (path.split('/').pop() === normalizedId) {
      imageSrc = module.default;
      break;
    }
  }
}
---

{svgContent ? (
  <span class="inline-icon" role="presentation" aria-hidden="true" set:html={svgContent} />
) : imageSrc ? (
  <img
    src={imageSrc.src}
    alt={alt}
    width={parseInt(width.replace('px', '')) || 20}
    class="inline-icon"
    style={`width: ${width}; height: auto;`}
  />
) : (
  <code>{alt}</code>
)}

