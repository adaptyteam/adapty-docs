---
interface Props {
  id: string;
  alt: string;
  width?: string;
}

const { id, alt, width = '20px' } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/Inline/**/*.{png,jpg,jpeg,webp,gif,svg}',
  { eager: true }
);

const normalizedId = id.split('/').pop() || id;
let imageSrc: ImageMetadata | undefined;

for (const [path, module] of Object.entries(allImages)) {
  if (path.split('/').pop() === normalizedId) {
    imageSrc = module.default;
    break;
  }
}
---

{imageSrc ? (
  <img
    src={imageSrc.src}
    alt={alt}
    width={parseInt(width.replace('px', '')) || 20}
    class="inline-icon"
    style={`width: ${width}; height: auto;`}
  />
) : (
  <code>{alt}</code>
)}

