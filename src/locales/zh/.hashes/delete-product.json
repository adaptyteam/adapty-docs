{"fileHash":"sha256:f2885455a4d258952f3dd53345a688aef7c51d905f33030540206aeeb5217eae","sections":{"preamble-pf4a910e7":{"contentHash":"sha256:f4a910e7fd29995069762cd52b6bc8402bfb4360fb58a05d874916f59e7a36f1","proseHash":"sha256:f4a910e7fd29995069762cd52b6bc8402bfb4360fb58a05d874916f59e7a36f1","translation":"---\ntitle: \"删除产品\"\ndescription: \"了解如何在 Adapty 中删除订阅产品，同时不影响应用的收入流。\"\nmetadataTitle: \"如何删除产品 | Adapty 文档\"\n---\n\nimport Zoom from 'react-medium-image-zoom';\nimport 'react-medium-image-zoom/dist/styles.css';\n\n您只能删除未在付费墙中使用的产品。\n\n要删除产品，请执行以下步骤：\n\n1. 从 Adapty 主菜单进入 **[Products](https://app.adapty.io/products)**。\n2. 点击产品旁边的 **3-dot** 按钮，然后选择 **Delete**。\n"},"preamble-p602e4918":{"contentHash":"sha256:602e491845cb39ab80464ab425f7a647bbe90a3c39eebc25ba3025e23070e5a8","proseHash":"sha256:602e491845cb39ab80464ab425f7a647bbe90a3c39eebc25ba3025e23070e5a8","translation":"<Zoom>\n  <img src=\"/assets/shared/img/delete-product.png\"\n  style={{\n    border: '1px solid #727272', /* border width and color */\n    width: '700px', /* image width */\n    display: 'block', /* for alignment */\n    margin: '0 auto' /* center alignment */\n  }}\n/>\n</Zoom>\n\n2. 输入您要删除的产品名称。\n"},"preamble-p3de745d5":{"contentHash":"sha256:3de745d57aed698243b2fd4c244cb44218a3a330d6c5d3b617f1c6073872d5b2","proseHash":"sha256:3de745d57aed698243b2fd4c244cb44218a3a330d6c5d3b617f1c6073872d5b2","translation":"<Zoom>\n  <img src=\"/assets/shared/img/b945add-delete_product.webp\"\n  style={{\n    border: '1px solid #727272', /* border width and color */\n    width: '700px', /* image width */\n    display: 'block', /* for alignment */\n    margin: '0 auto' /* center alignment */\n  }}\n/>\n</Zoom>\n\n3. 点击 **Delete forever**。"}}}